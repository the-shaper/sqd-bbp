# AI_PROVIDER: Default provider for models that do not imply a provider directly.
# Supported values: "opencode", "google", "openrouter"
AI_PROVIDER="opencode"

# AI_DEFAULT_MODEL: Default model used by server AI routes if the client does not pass one.
AI_DEFAULT_MODEL="minimax-m2.5"

# GOOGLE_API_KEY / GEMINI_API_KEY: Google AI key used for Gemini models.
# Keep either variable name if your deployment platform standardizes on one of them.
GOOGLE_API_KEY="MY_GOOGLE_API_KEY"
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENCODE_API_KEY: Key used for Opencode-backed models such as MiniMax through the Opencode proxy.
OPENCODE_API_KEY="MY_OPENCODE_API_KEY"

# OPENROUTER_API_KEY: Key used for OpenRouter-backed models such as "openrouter/auto".
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# ADMIN_PASSWORD: Password for accessing the admin dashboard.
# Default: "shazam!"
ADMIN_PASSWORD="shazam!"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PARTYKIT_HOST: The PartyKit host for the Express backend when minting realtime auth.
PARTYKIT_HOST="localhost:1999"

# PARTYKIT_ADMIN_SECRET: Shared secret used to sign and verify admin PartyKit tokens.
PARTYKIT_ADMIN_SECRET="replace-me"

# VITE_PARTYKIT_HOST: The PartyKit host used by the browser client.
VITE_PARTYKIT_HOST="localhost:1999"

# VITE_PARTYKIT_PARTY: Optional PartyKit party name override.
VITE_PARTYKIT_PARTY="main"
